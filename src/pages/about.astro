---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Scientific Calculator Online"
  description="About Scientific Calculator Online — free TI-30XS MultiView compatible calculator for students."
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-6">About Scientific Calculator Online</h1>
    <div class="text-text-muted space-y-4">
      <p>
        Scientific Calculator Online provides free, browser-based scientific calculators
        compatible with popular calculator models used in education.
      </p>
      <p>
        Our mission is to give every student free access to the calculator tools they need
        for their coursework and standardized tests. No downloads, no subscriptions —
        just open your browser and start calculating.
      </p>
      <h2 class="text-xl font-semibold text-text pt-4">Our Calculators</h2>
      <p>
        We currently offer a scientific calculator compatible with TI-30XS MultiView
        coursework, featuring MathPrint display, fraction operations, trigonometry,
        statistics, and table mode. More calculator models are coming soon.
      </p>
      <h2 class="text-xl font-semibold text-text pt-4">Independent Project</h2>
      <p>
        This is an independent project. We are not affiliated with, endorsed by, or
        sponsored by Texas Instruments Inc. or any calculator manufacturer. All product
        names and trademarks are the property of their respective owners and are used
        here solely for identification and compatibility purposes.
      </p>
    </div>
  </div>
</BaseLayout>
