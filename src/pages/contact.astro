---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Scientific Calculator Online"
  description="Contact Scientific Calculator Online for feedback, bug reports, or questions."
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-6">Contact Us</h1>
    <div class="text-text-muted space-y-4">
      <p>
        Have feedback, found a bug, or have a question? We'd love to hear from you.
      </p>
      <div class="bg-bg-card rounded-xl border border-border p-6">
        <h2 class="text-lg font-semibold text-text mb-3">Get in Touch</h2>
        <ul class="space-y-2 text-sm">
          <li>
            <strong class="text-text">Bug Reports & Feature Requests:</strong>
            <a href="https://github.com/chybot/scientific-calculator-online/issues" class="text-primary hover:underline ml-1">GitHub Issues</a>
          </li>
          <li>
            <strong class="text-text">General Inquiries:</strong>
            <span class="ml-1">contact@scientificcalc.com</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>
